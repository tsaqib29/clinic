<section class="py-8 sm:py-10 px-3 sm:px-6 bg-gray-50 min-h-screen">

  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
        💰 Keuangan Klinik
      </h1>
      <p class="text-xs sm:text-sm text-gray-500 mt-1">
        Ringkasan pemasukan dari kunjungan pasien
      </p>
    </div>

    <!-- CARDS -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-8">

      <!-- TODAY -->
      <div class="bg-white p-5 rounded-2xl shadow-sm border hover:shadow-md transition">
        <div class="flex justify-between items-center mb-2">
          <p class="text-gray-500 text-xs">Hari Ini</p>
          <span class="text-green-500 text-lg">📈</span>
        </div>
        <p class="text-xl sm:text-2xl font-bold text-green-600">
          <%= number_to_currency(@today_income, unit:"Rp ", delimiter:".", precision:0) %>
        </p>
      </div>

      <!-- MONTH -->
      <div class="bg-white p-5 rounded-2xl shadow-sm border hover:shadow-md transition">
        <div class="flex justify-between items-center mb-2">
          <p class="text-gray-500 text-xs">Bulan Ini</p>
          <span class="text-blue-500 text-lg">📊</span>
        </div>
        <p class="text-xl sm:text-2xl font-bold text-blue-600">
          <%= number_to_currency(@month_income, unit:"Rp ", delimiter:".", precision:0) %>
        </p>
      </div>

      <!-- TOTAL -->
      <div class="bg-white p-5 rounded-2xl shadow-sm border hover:shadow-md transition">
        <div class="flex justify-between items-center mb-2">
          <p class="text-gray-500 text-xs">Total</p>
          <span class="text-purple-500 text-lg">💎</span>
        </div>
        <p class="text-xl sm:text-2xl font-bold text-purple-600">
          <%= number_to_currency(@total_income, unit:"Rp ", delimiter:".", precision:0) %>
        </p>
      </div>

    </div>

    <!-- TABLE -->
    <div class="bg-white rounded-2xl shadow-sm border">

      <!-- HEADER -->
      <div class="px-5 py-4 border-b flex justify-between items-center">
        <h2 class="text-sm sm:text-base font-semibold text-gray-700">
          Riwayat Income
        </h2>
      </div>

      <!-- DESKTOP TABLE -->
      <div class="hidden sm:block overflow-x-auto">
        <table class="w-full text-sm">

          <thead class="bg-gray-50 text-gray-600">
            <tr>
              <th class="p-3 text-left">Tanggal</th>
              <th class="p-3 text-left">Pasien</th>
              <th class="p-3 text-left">Biaya</th>
            </tr>
          </thead>

          <tbody>
            <% if @visits.present? %>
              <% @visits.each do |visit| %>

                <tr class="border-t hover:bg-gray-50 transition">

                  <td class="p-3 text-gray-700">
                    <%= visit.visit_date&.strftime("%d %b %Y") %>
                  </td>

                  <td class="p-3 font-medium text-gray-800">
                    <%= visit.patient.name %>
                  </td>

                  <td class="p-3 font-semibold text-green-600">
                    <%= number_to_currency(visit.cost, unit:"Rp ", delimiter:".", precision:0) %>
                  </td>

                </tr>

              <% end %>
            <% else %>
              <tr>
                <td colspan="3" class="p-6 text-center text-gray-400">
                  Belum ada data income
                </td>
              </tr>
            <% end %>
          </tbody>

        </table>
      </div>

      <!-- MOBILE VERSION -->
      <div class="sm:hidden divide-y">

        <% if @visits.present? %>

          <% @visits.each do |visit| %>

            <div class="p-4">

              <div class="text-xs text-gray-500 mb-1">
                <%= visit.visit_date&.strftime("%d %b %Y") %>
              </div>

              <div class="font-medium text-gray-800">
                <%= visit.patient.name %>
              </div>

              <div class="text-green-600 font-semibold mt-1">
                <%= number_to_currency(visit.cost, unit:"Rp ", delimiter:".", precision:0) %>
              </div>

            </div>

          <% end %>

        <% else %>

          <div class="p-6 text-center text-gray-400">
            Belum ada data income
          </div>

        <% end %>

      </div>

    </div>

  </div>

</section>