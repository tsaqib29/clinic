<div class="max-w-md mx-auto bg-white p-5 sm:p-6 rounded-2xl shadow-lg border border-gray-100">

  <!-- HEADER -->
  <h1 class="text-lg sm:text-xl font-semibold text-gray-800 mb-5 text-center">
    ➕ Tambah Janji
  </h1>

  <%= form_with model: [:admin, @appointment],
        data: { turbo_frame: "_top" },
        class:"space-y-4" do |f| %>

    <!-- PASIEN -->
    <div>
      <%= f.label :patient_id, "Pasien",
            class:"block text-xs sm:text-sm font-medium text-gray-600 mb-1" %>

      <%= f.collection_select :patient_id, Patient.active, :id, :name,
            { prompt: "Pilih pasien" },
            class:"w-full border border-gray-200 rounded-xl px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <!-- TANGGAL -->
    <div>
      <%= f.label :scheduled_date, "Tanggal",
            class:"block text-xs sm:text-sm font-medium text-gray-600 mb-1" %>

      <%= f.date_field :scheduled_date,
            value: @date,
            class:"w-full border border-gray-200 rounded-xl px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <!-- CATATAN -->
    <div>
      <%= f.label :note, "Catatan",
            class:"block text-xs sm:text-sm font-medium text-gray-600 mb-1" %>

      <%= f.text_area :note,
            rows: 3,
            placeholder: "Contoh: pasien kontrol, bawa hasil lab...",
            class:"w-full border border-gray-200 rounded-xl px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" %>
    </div>

    <!-- BUTTON -->
    <div class="flex gap-2 pt-3">

      <%= f.submit "Simpan",
            class:"flex-1 bg-blue-600 hover:bg-blue-700 active:scale-95
                   text-white py-2 rounded-xl text-sm font-semibold transition" %>

      <%= link_to "Batal",
            admin_visits_path,
            data: { turbo_frame: "_top" },
            class:"flex-1 text-center bg-gray-100 hover:bg-gray-200 active:scale-95
                   text-gray-700 py-2 rounded-xl text-sm font-semibold transition" %>

    </div>

  <% end %>

</div>