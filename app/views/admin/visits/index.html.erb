<turbo-frame id="calendar">
  <div class="p-3 sm:p-6 bg-gray-50 min-h-screen">

    <div class="bg-white rounded-2xl shadow border p-4 sm:p-6">

      <!-- HEADER -->
      <div class="flex items-center justify-between mb-4">

        <%= link_to "<",
            admin_visits_path(date: @date.prev_month.beginning_of_month),
            data: { turbo_frame: "calendar" },
            class:"px-3 py-1 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm" %>

        <h2 class="text-base sm:text-lg font-semibold text-gray-800 text-center">
          📅 <%= @date.strftime("%B %Y") %>
        </h2>

        <%= link_to ">",
            admin_visits_path(date: @date.next_month.beginning_of_month),
            data: { turbo_frame: "calendar" },
            class:"px-3 py-1 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm" %>
      </div>

      <!-- HARI -->
      <div class="grid grid-cols-7 text-[10px] sm:text-xs font-semibold text-gray-500 mb-1">
        <% %w[Sen Sel Rab Kam Jum Sab Min].each do |d| %>
          <div class="text-center"><%= d %></div>
        <% end %>
      </div>

      <!-- TANGGAL -->
      <div class="grid grid-cols-7 gap-1 sm:gap-2">

        <% start_date = @date.beginning_of_month.beginning_of_week(:monday) %>
        <% end_date   = @date.end_of_month.end_of_week(:monday) %>

        <% (start_date..end_date).each do |day| %>

          <% total = (@visit_counts[day] || 0) + (@appointment_counts[day] || 0) %>

          <div class="relative rounded-xl p-2 sm:p-3 h-20 sm:h-24
                      border bg-white hover:bg-blue-50 transition
                      <%= 'opacity-40' if day.month != @date.month %>
                      <%= 'ring-2 ring-blue-400' if day == Date.today %>">

            <!-- tanggal -->
            <div class="text-xs sm:text-sm font-bold text-gray-700">
              <%= day.day %>
            </div>

            <!-- badge jumlah -->
            <% if total > 0 %>
              <div class="mt-1 inline-block text-[10px] sm:text-xs px-2 py-0.5
                          bg-blue-100 text-blue-700 rounded-full">
                <%= total %>
              </div>
            <% end %>

            <!-- klik -->
            <%= link_to "", admin_visits_path(date: day), data: { turbo_frame: "modal" }, class:"absolute inset-0 z-10" %>

          </div>

        <% end %>
      </div>

    </div>

  </div>
</turbo-frame>
