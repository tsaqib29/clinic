<% content_for :title, "Detail Kunjungan" %>

<section class="py-8 sm:py-10 px-3 sm:px-6 lg:px-8 bg-gray-50 min-h-screen">
  <div class="max-w-3xl mx-auto">

    <!-- NOTICE -->
    <% if notice.present? %>
      <div class="mb-5 p-3 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm">
        <%= notice %>
      </div>
    <% end %>

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-xl sm:text-2xl font-bold text-gray-800">
        📄 Detail Kunjungan
      </h1>
      <p class="text-xs sm:text-sm text-gray-500 mt-1">
        Informasi pasien & riwayat kunjungan
      </p>
    </div>

    <!-- DATA PASIEN -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-5 sm:p-6 mb-5">
      <%= render @patient %>
    </div>

    <!-- RIWAYAT -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-5 sm:p-6 mb-5">

      <div class="flex justify-between items-center mb-4">
        <h2 class="text-base sm:text-lg font-semibold text-gray-800">
          Riwayat Kunjungan
        </h2>

        <%= link_to new_admin_patient_visit_path(@patient),
            class:"bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-lg text-xs sm:text-sm font-medium" do %>
          ➕ Tambah
        <% end %>
      </div>

      <!-- TABLE DESKTOP -->
      <div class="hidden sm:block overflow-x-auto">
        <table class="w-full text-sm">

          <thead class="bg-gray-50 border-b text-gray-600">
            <tr>
              <th class="py-2 px-3 text-left">Datang</th>
              <th class="py-2 px-3 text-left">Kontrol</th>
              <th class="py-2 px-3 text-left">Biaya</th>
              <th class="py-2 px-3 text-center">Aksi</th>
            </tr>
          </thead>

          <tbody>
            <% @patient.visits.each do |visit| %>
              <tr class="border-b hover:bg-gray-50">

                <td class="py-2 px-3">
                  <%= visit.visit_date %>
                </td>

                <td class="py-2 px-3">
                  <%= visit.next_visit_date %>
                </td>

                <td class="py-2 px-3 font-medium">
                  <%= number_to_currency(visit.cost, unit:"Rp ", delimiter:".", precision:0) %>
                </td>

                <td class="py-2 px-3 text-center">
                  <div class="flex justify-center gap-2">

                    <!-- EDIT -->
                    <%= link_to edit_admin_patient_visit_path(@patient, visit),
                        class:"p-2 rounded-lg hover:bg-yellow-100" do %>
                      ✏️
                    <% end %>

                    <!-- DELETE -->
                    <%= button_to admin_patient_visit_path(@patient, visit),
                        method: :delete,
                        data: { turbo: false, turbo_confirm: "Hapus data ini?" },
                        class:"p-2 rounded-lg hover:bg-red-100" do %>
                      🗑
                    <% end %>

                  </div>
                </td>

              </tr>
            <% end %>
          </tbody>

        </table>
      </div>

      <!-- MOBILE VERSION -->
      <div class="sm:hidden space-y-3">
        <% @patient.visits.each do |visit| %>

          <div class="border rounded-xl p-3">

            <div class="text-xs text-gray-500 mb-1">
              Datang: <span class="text-gray-800"><%= visit.visit_date %></span>
            </div>

            <div class="text-xs text-gray-500 mb-1">
              Kontrol: <span class="text-gray-800"><%= visit.next_visit_date %></span>
            </div>

            <div class="text-sm font-semibold mb-2">
              <%= number_to_currency(visit.cost, unit:"Rp ", delimiter:".", precision:0) %>
            </div>

            <div class="flex gap-2 justify-end">

              <%= link_to edit_admin_patient_visit_path(@patient, visit),
                  class:"p-2 rounded-lg bg-yellow-100" do %>
                ✏️
              <% end %>

              <%= button_to admin_patient_visit_path(@patient, visit),
                  method: :delete,
                  data: { turbo: false, turbo_confirm: "Hapus?" },
                  class:"p-2 rounded-lg bg-red-100" do %>
                🗑
              <% end %>

            </div>

          </div>

        <% end %>
      </div>

    </div>

    <!-- ACTION -->
    <div class="flex flex-col sm:flex-row gap-2">

      <%= link_to edit_admin_patient_path(@patient),
          class:"flex-1 text-center bg-blue-600 hover:bg-blue-700 text-white py-2.5 rounded-xl text-sm font-semibold transition" do %>
        ✏️ Edit
      <% end %>

      <%= button_to [:admin, @patient],
          method: :delete,
          data: { turbo: false, turbo_confirm: "Yakin hapus pasien?" },
          class:"flex-1 bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-xl text-sm font-semibold transition" do %>
        🗑 Hapus
      <% end %>

      <%= link_to admin_patients_path,
          class:"flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 py-2.5 rounded-xl text-sm font-medium transition" do %>
        ← Pasien
      <% end %>

      <%= link_to admin_visits_path,
          class:"flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 py-2.5 rounded-xl text-sm font-medium transition" do %>
        ← Kalender
      <% end %>

    </div>

  </div>
</section>