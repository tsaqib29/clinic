<!DOCTYPE html>
<html>
  <head>
    <title>Sinshe Tommy</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="manifest" href="/manifest.json" data-turbo-track="reload">
    <meta name="theme-color" content="#2563eb">
  </head>

  <body class="bg-slate-50">
    <turbo-frame id="modal"></turbo-frame>

    <% if notice %>
      <div class="toast fixed top-5 right-5 z-50 bg-green-500 text-white px-4 py-3 rounded-xl shadow-lg text-sm transition-all duration-300">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="toast fixed top-5 right-5 z-50 bg-red-500 text-white px-4 py-3 rounded-xl shadow-lg text-sm transition-all duration-300">
        <%= alert %>
      </div>
    <% end %>

  <!-- HEADER -->
  <header class="bg-white shadow-sm sticky top-0 z-50">

    <!-- BAR ATAS -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-[56px] flex items-center justify-between">
      <!-- KIRI: Logo + Hamburger -->
      <div class="flex items-center justify-between w-full font-semibold text-gray-800">

      <!-- KIRI -->
      <div class="flex items-center gap-3">
        <!-- Hamburger (Mobile) -->
        <button id="menuBtn" class="md:hidden text-2xl focus:outline-none">
          ☰
        </button>

        <!-- Logo + Text (Desktop) -->
        <div class="hidden md:flex items-center gap-2">
          <%= image_tag "yang.png", class: "h-8 w-8 object-contain" %>
          <%= link_to "SINSHE TOMMY", root_path %>
        </div>
      </div>

      <!-- KANAN -->
      <div class="flex items-center gap-2">
        <!-- Logo (Mobile Only) -->
        <div class="md:hidden flex items-center gap-2">
          <%= link_to root_path do %>
            <%= image_tag "yang.png", class: "h-8 w-8 object-contain" %>
          <% end %>
        </div>
      </div>
    </div>

      <!-- Desktop Login -->
      <div class="hidden md:block">
        <% if admin_user_signed_in? %>
          <%= button_to "Logout",
                destroy_admin_user_session_path,
                method: :delete,
                class:"bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-full text-sm" %>
        <% else %>
          <%= link_to "Masuk",
                admin_user_session_path,
                class:"bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-full text-sm" %>
        <% end %>
      </div>
    </div>

    <!-- DESKTOP MENU -->
    <div class="hidden md:flex max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-[40px] items-center justify-between text-sm text-gray-700">

      <div class="flex items-center gap-6">
        <%= link_to "Beranda", root_path, class:"hover:text-blue-600" %>
        <% if admin_user_signed_in? %>
          <%= link_to "Data Pasien", admin_patients_path, class:"hover:text-blue-600" %>
          <%= link_to "Keuangan", admin_finance_path, class:"hover:text-blue-600" %>
          <%= link_to "Kunjungan", admin_visits_path, class:"hover:text-blue-600" %>
        <% end %>
      </div>

      <%= link_to "Kontak Bantuan", "#",
        class:"text-xs hover:text-blue-600" %>

    </div>

    <!-- SIDEBAR -->
    <div id="mobileMenu"
      class="fixed top-0 left-0 h-full w-72 bg-white/95 backdrop-blur-xl shadow-2xl
            transform -translate-x-full transition-all duration-300 ease-out z-50 flex flex-col">

      <!-- HEADER -->
      <div class="flex items-center justify-between px-5 py-4 border-b">

        <div class="flex items-center gap-3">
          <%= image_tag "yang.png", class: "h-8 w-8" %>
          <span class="font-semibold text-gray-800">Sinshe Tommy</span>
        </div>

        <button id="closeMenu"
          class="text-gray-400 hover:text-red-500 text-xl transition">
          ✕
        </button>
      </div>

      <!-- MENU -->
      <nav class="flex-1 px-3 py-4 space-y-1 text-sm">

        <%= link_to root_path, onclick: "closeMenu()",
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-house text-gray-400"></i>
          Beranda
        <% end %>

      <% if admin_user_signed_in? %>
        <%= link_to admin_patients_path, onclick: "closeMenu()",
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-users text-gray-400"></i>
          Data Pasien
        <% end %>

        <%= link_to admin_visits_path, onclick: "closeMenu()",
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-calendar text-gray-400"></i>
          Kunjungan
        <% end %>

        <%= link_to admin_finance_path, onclick: "closeMenu()",
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-money-bill text-gray-400"></i>
          Keuangan
        <% end %>
      <% end %>
      </nav>

      <!-- FOOTER -->
      <div class="p-4">

        <% if admin_user_signed_in? %>
          <%= button_to "Logout",
                destroy_admin_user_session_path,
                method: :delete,
                class:"bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-full text-sm" %>
        <% else %>
          <%= link_to "Masuk",
                admin_user_session_path,
                class:"bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-full text-sm" %>
        <% end %>

      </div>

    </div>
  </header>

  <!-- CONTENT -->
  <main id="pageContent" class="transition-all duration-300">
    <%= yield %>
  </main>

  <script>
    document.addEventListener("turbo:load", function() {
      const menuBtn = document.getElementById("menuBtn");
      const mobileMenu = document.getElementById("mobileMenu");
      const closeMenu = document.getElementById("closeMenu");
      const overlay = document.getElementById("overlay");

      function openMenu() {
        mobileMenu.classList.remove("-translate-x-full");
        overlay.classList.remove("opacity-0", "pointer-events-none");
      }

      function closeMenuFunc() {
        mobileMenu.classList.add("-translate-x-full");
        overlay.classList.add("opacity-0", "pointer-events-none");
      }

      if (menuBtn) menuBtn.onclick = openMenu;
      if (closeMenu) closeMenu.onclick = closeMenuFunc;
      if (overlay) overlay.onclick = closeMenuFunc;
    });

    function openModal() {
      const wrapper = document.getElementById("modalWrapper");
      const content = document.getElementById("modalContent");

      if (!wrapper || !content) return;

      wrapper.classList.remove("opacity-0", "pointer-events-none");
      content.classList.remove("translate-y-full", "sm:scale-95");
    }

    function closeModal() {
      const wrapper = document.getElementById("modalWrapper");
      const content = document.getElementById("modalContent");

      if (!wrapper || !content) return;

      wrapper.classList.add("opacity-0");
      content.classList.add("translate-y-full", "sm:scale-95");

      setTimeout(() => {
        wrapper.classList.add("pointer-events-none");
        document.getElementById("modal").innerHTML = "";
      }, 300);
    }

    document.addEventListener("turbo:frame-load", function(e) {
      if (e.target.id === "modal") {
        setTimeout(openModal, 10);
      }
    });

    document.addEventListener("turbo:visit", () => {
      const page = document.getElementById("pageContent");
      if (page) {
        page.classList.add("page-leave");
      }
    });

    document.addEventListener("turbo:load", () => {
      const page = document.getElementById("pageContent");

      if (page) {
        page.classList.add("page-enter");

        setTimeout(() => {
          page.classList.add("page-enter-active");
        }, 10);

        setTimeout(() => {
          page.classList.remove("page-enter", "page-enter-active");
        }, 300);
      }
    });

    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/service-worker.js")
        .then(() => console.log("Service Worker Registered"));
    }

    let deferredPrompt;

    window.addEventListener("beforeinstallprompt", (e) => {
      e.preventDefault();
      deferredPrompt = e;

      // contoh auto trigger
      setTimeout(() => {
        if (deferredPrompt) {
          deferredPrompt.prompt();
          deferredPrompt.userChoice.then(() => {
            deferredPrompt = null;
          });
        }
      }, 3000);
    });

    document.addEventListener("turbo:load", () => {
      const toasts = document.querySelectorAll(".toast");

      toasts.forEach((toast) => {
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateY(-10px)";
        }, 2500);

        setTimeout(() => {
          toast.remove();
        }, 3000);
      });
    });
  </script>
</body>
</html>