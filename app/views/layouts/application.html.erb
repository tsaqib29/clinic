<!DOCTYPE html>
<html>
  <head>
    <title>Sinshe Tommy</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <turbo-frame id="modal"></turbo-frame>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  </head>

  <body class="bg-slate-50">

  <!-- HEADER -->
  <header class="bg-white shadow-sm sticky top-0 z-50">

    <!-- BAR ATAS -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-[56px] flex items-center justify-between">
      <!-- KIRI: Logo + Hamburger -->
      <div class="flex items-center justify-between w-full font-semibold text-gray-800">

      <!-- KIRI -->
      <div class="flex items-center gap-3">
        <!-- Hamburger (Mobile) -->
        <button id="menuBtn" class="md:hidden text-2xl focus:outline-none">
          ☰
        </button>

        <!-- Logo + Text (Desktop) -->
        <div class="hidden md:flex items-center gap-2">
          <%= image_tag "yang.png", class: "h-8 w-8 object-contain" %>
          <%= link_to "SINSHE TOMMY", root_path %>
        </div>
      </div>

      <!-- KANAN -->
      <div class="flex items-center gap-2">
        <!-- Logo (Mobile Only) -->
        <div class="md:hidden flex items-center gap-2">
          <%= link_to root_path do %>
            <%= image_tag "yang.png", class: "h-8 w-8 object-contain" %>
          <% end %>
        </div>
      </div>
    </div>

      <!-- Desktop Login -->
      <div class="hidden md:block">
        <%= link_to "Masuk", admin_user_session_path,
          class:"bg-blue-600 hover:bg-green-600 text-white px-4 py-2 rounded-full text-sm font-semibold" %>
      </div>
    </div>

    <!-- DESKTOP MENU -->
    <div class="hidden md:flex max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-[40px] items-center justify-between text-sm text-gray-700">

      <div class="flex items-center gap-6">
        <%= link_to "Beranda", root_path, class:"hover:text-blue-600" %>
        <%= link_to "Data Pasien", patients_path, class:"hover:text-blue-600" %>
        <%= link_to "Keuangan", finance_path, class:"hover:text-blue-600" %>
        <%= link_to "Kunjungan", visits_path, class:"hover:text-blue-600" %>
      </div>

      <%= link_to "Kontak Bantuan", "#",
        class:"text-xs hover:text-blue-600" %>

    </div>

    <!-- SIDEBAR -->
    <div id="mobileMenu"
      class="fixed top-0 left-0 h-full w-72 bg-white/95 backdrop-blur-xl shadow-2xl
            transform -translate-x-full transition-all duration-300 ease-out z-50 flex flex-col">

      <!-- HEADER -->
      <div class="flex items-center justify-between px-5 py-4 border-b">

        <div class="flex items-center gap-3">
          <%= image_tag "yang.png", class: "h-8 w-8" %>
          <span class="font-semibold text-gray-800">Sinshe Tommy</span>
        </div>

        <button id="closeMenu"
          class="text-gray-400 hover:text-red-500 text-xl transition">
          ✕
        </button>
      </div>

      <!-- MENU -->
      <nav class="flex-1 px-3 py-4 space-y-1 text-sm">

        <%= link_to root_path,
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-house text-gray-400"></i>
          Beranda
        <% end %>

        <%= link_to patients_path,
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-users text-gray-400"></i>
          Data Pasien
        <% end %>

        <%= link_to visits_path,
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-calendar text-gray-400"></i>
          Kunjungan
        <% end %>

        <%= link_to finance_path,
          class: "flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-all duration-200" do %>
          <i class="fa-solid fa-money-bill text-gray-400"></i>
          Keuangan
        <% end %>

      </nav>

      <!-- FOOTER -->
      <div class="p-4">

        <%= link_to admin_user_session_path,
          class:"block text-center bg-blue-600 hover:bg-blue-700 text-white py-2.5 rounded-xl text-sm font-semibold transition" do %>
          Masuk
        <% end %>

      </div>

    </div>
  </header>

  <!-- CONTENT -->
  <main>
    <%= yield %>
  </main>

  <script>
    document.addEventListener("turbo:load", function() {
      const menuBtn = document.getElementById("menuBtn");
      const mobileMenu = document.getElementById("mobileMenu");
      const closeMenu = document.getElementById("closeMenu");
      const overlay = document.getElementById("overlay");

      function openMenu() {
        mobileMenu.classList.remove("-translate-x-full");
        overlay.classList.remove("opacity-0", "pointer-events-none");
      }

      function closeMenuFunc() {
        mobileMenu.classList.add("-translate-x-full");
        overlay.classList.add("opacity-0", "pointer-events-none");
      }

      if (menuBtn) menuBtn.onclick = openMenu;
      if (closeMenu) closeMenu.onclick = closeMenuFunc;
      if (overlay) overlay.onclick = closeMenuFunc;
    });

    function openModal() {
      const wrapper = document.getElementById("modalWrapper");
      const content = document.getElementById("modalContent");

      if (!wrapper || !content) return;

      wrapper.classList.remove("opacity-0", "pointer-events-none");
      content.classList.remove("translate-y-full", "sm:scale-95");
    }

    function closeModal() {
      const wrapper = document.getElementById("modalWrapper");
      const content = document.getElementById("modalContent");

      if (!wrapper || !content) return;

      wrapper.classList.add("opacity-0");
      content.classList.add("translate-y-full", "sm:scale-95");

      setTimeout(() => {
        wrapper.classList.add("pointer-events-none");
        document.getElementById("modal").innerHTML = "";
      }, 300);
    }

    document.addEventListener("turbo:frame-load", function(e) {
      if (e.target.id === "modal") {
        setTimeout(openModal, 10);
      }
    });
  </script>
</body>
</html>