<!DOCTYPE html>
<html>
  <head>
    <title>Sinshe Tommy</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  </head>

  <body class="bg-slate-50">

  <!-- HEADER -->
  <header class="bg-white shadow-sm sticky top-0 z-50">

    <!-- BAR ATAS -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-[56px] flex items-center justify-between">

      <!-- KIRI: Logo + Hamburger -->
      <div class="flex items-center justify-between w-full font-semibold text-gray-800">

        <!-- Hamburger (Mobile Only) -->
        <button id="menuBtn" class="md:hidden text-2xl focus:outline-none">
          ☰
        </button>

        <!-- Logo -->
        <div>
          <%= link_to "SINSHE TOMMY", root_path %>
        </div>

      </div>

      <!-- Desktop Login -->
      <div class="hidden md:block">
        <%= link_to "Masuk", admin_user_session_path,
          class:"bg-blue-600 hover:bg-green-600 text-white px-4 py-2 rounded-full text-sm font-semibold" %>
      </div>

    </div>

    <!-- DESKTOP MENU -->
    <div class="hidden md:flex max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-[40px] items-center justify-between text-sm text-gray-700">

      <div class="flex items-center gap-6">
        <%= link_to "Beranda", root_path, class:"hover:text-blue-600" %>
        <%= link_to "Data Pasien", patients_path, class:"hover:text-blue-600" %>
        <%= link_to "Keuangan", finance_path, class:"hover:text-blue-600" %>
        <%= link_to "Kunjungan", tomorrow_visits_path, class:"hover:text-blue-600" %>
      </div>

      <%= link_to "Kontak Bantuan", "#",
        class:"text-xs hover:text-blue-600" %>

    </div>

  <!-- SIDEBAR MENU -->
  <div id="mobileMenu"
      class="fixed top-0 left-0 h-full w-64 bg-white shadow-2xl border-r border-gray-200 transform -translate-x-full transition-transform duration-300 z-50">

    <!-- HEADER MENU -->
    <div class="flex items-center justify-between p-5 border-b">
      <span class="font-semibold text-lg">Menu</span>

      <!-- TOMBOL CLOSE -->
      <button id="closeMenu"
              class="text-gray-500 hover:text-red-500 text-2xl font-bold">
        &times;
      </button>
    </div>

    <!-- MENU ITEMS -->
    <%= link_to "Beranda", root_path,
        class:"block px-6 py-4 border-b hover:bg-gray-100" %>

    <%= link_to "Data Pasien", patients_path,
        class:"block px-6 py-4 border-b hover:bg-gray-100" %>

    <%= link_to "Keuangan", finance_path,
        class:"block px-6 py-4 border-b hover:bg-gray-100" %>

    <%= link_to "Kunjungan", tomorrow_visits_path,
        class:"block px-6 py-4 border-b hover:bg-gray-100" %>

    <%= link_to "Kontak Bantuan", "#",
        class:"block px-6 py-4 border-b hover:bg-gray-100" %>

    <%= link_to "Masuk", admin_user_session_path,
        class:"block px-6 py-4 text-blue-600 font-semibold" %>

  </div>

  </header>

  <!-- CONTENT -->
  <main>
    <%= yield %>
  </main>

  <script>
    document.addEventListener("turbo:load", function() {
      const menuBtn = document.getElementById("menuBtn");
      const mobileMenu = document.getElementById("mobileMenu");
      const closeMenu = document.getElementById("closeMenu");

      if (menuBtn) {
        menuBtn.addEventListener("click", () => {
          mobileMenu.classList.remove("-translate-x-full");
        });
      }

      if (closeMenu) {
        closeMenu.addEventListener("click", () => {
          mobileMenu.classList.add("-translate-x-full");
        });
      }
    });
</script>
</body>
</html>