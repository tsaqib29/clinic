<div class="bg-gray-50">
  <!-- Hero -->
  <section class="bg-gray-100 py-10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="bg-blue-600 text-white rounded-2xl px-8 py-12 relative overflow-hidden">

        <!-- Statistik (KIRI ATAS) -->
        <div class="absolute top-6 left-8 flex flex-wrap gap-8 text-sm">

          <div class="flex items-center gap-2">
            <i class="fa-solid fa-star text-yellow-300 text-lg"></i>
            <div>
              <div class="font-bold text-base"><%= @rating %></div>
              <div class="opacity-80 text-xs">Penilaian</div>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <i class="fa-solid fa-comments text-lg"></i>
            <div>
              <div class="font-bold text-base"><%= @reviews_count %></div>
              <div class="opacity-80 text-xs">Ulasan</div>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <i class="fa-solid fa-heart text-pink-300 text-lg"></i>
            <div>
              <div class="font-bold text-base"><%= @patients_recovered %></div>
              <div class="opacity-80 text-xs">Pasien Sembuh</div>
            </div>
          </div>

        </div>

        <!-- Konten Tengah -->
        <div class="text-center mt-16">

          <h1 class="text-4xl font-bold mb-4 tracking-wide">
            SINSHE TOMMY
          </h1>

          <p class="text-lg opacity-90 mb-6">
            Spesialis Pengobatan Tiongkok
          </p>

          <a href="/patients/new"
             class="inline-block bg-white text-blue-600 font-semibold px-6 py-3 rounded-lg hover:bg-gray-100 transition shadow-md">
            Daftar Kunjungan
          </a>

        </div>

      </div>
    </div>
  </section>

  <!-- Tentang Klinik -->
  <section class="py-16 text-center">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-10">

      <div>
        <h2 class="text-2xl font-bold mb-4">Tentang Kami</h2>
        <p class="text-gray-600 leading-relaxed">
          Merupakan klinik pengobatan tradisional Tiongkok
          yang ditangani langsung oleh Sinshe Tommy, dengan fokus pada pelayanan
          kesehatan yang profesional, aman, dan nyaman untuk membantu pasien
          dalam mengatasi berbagai keluhan secara menyeluruh.
        </p>
      </div>

      <div>
        <h2 class="text-2xl font-bold mb-4">Layanan</h2>
        <ul class="space-y-2 text-gray-600">
          <li>• Pemeriksaan Umum</li>
          <li>• Terapi / Akupuntur</li>
          <li>• Konsultasi Kesehatan</li>
          <li>• Perawatan Berkala</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Mengatasi Keluhan -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-6xl mx-auto px-6">

      <h2 class="text-2xl font-bold text-center mb-10">
        Mengatasi Keluhan
      </h2>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 text-sm">

        <% [
          "Stroke","Syaraf Kejepit","Jantung Koroner","Bell’s Palsy",
          "Lordosis","Scoliosis","Vertigo / GERD","Cedera",
          "Hipertensi","Diabetes","Impoten / ED","Insomnia",
          "Benjolan","Batu","Empedu","Gangguan Mata",
          "Amandel","Polip / Sinusitis","Gagal Ginjal","Batu Ginjal",
          "Ambeien","Asam Urat","Kolesterol","Gangguan Paru-paru",
          "Gangguan Lambung","Alergi","Dan lain-lain"
        ].each do |keluhan| %>

          <div class="bg-white p-4 rounded-lg shadow hover:shadow-lg transition text-center">
            <%= keluhan %>
          </div>

        <% end %>

      </div>

    </div>
  </section>

  <!-- Info -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-8 text-center">

      <div>
        <h3 class="font-semibold text-lg">Jam Operasional</h3>
        <p class="text-gray-600">
          Senin – Sabtu<br>
          08.00 – 17.00
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-lg">Alamat</h3>
        <p class="text-gray-600">
          Jl. Nicaragua RT 02 RW 07 Desa Ciseupan <br>
          Cibeber, Cimahi Selatan <br>
          (Maps: Sinshe Tommy)
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-lg">Kontak</h3>
        <p class="text-gray-600">
          0896-9736-9661
        </p>
      </div>

    </div>
  </section>

</div>
