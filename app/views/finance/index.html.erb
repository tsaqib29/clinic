<section class="py-10 px-6 bg-gray-50 min-h-screen">

<div class="max-w-6xl mx-auto">

<h1 class="text-3xl font-bold text-gray-800 mb-8">
💰 Keuangan Klinik
</h1>

<!-- CARD INCOME -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

<div class="bg-white p-6 rounded-2xl shadow-sm border hover:shadow-md transition">
<p class="text-gray-500 text-sm mb-1">Income Hari Ini</p>
<p class="text-2xl font-bold text-green-600">
<%= number_to_currency(@today_income, unit:"Rp ", delimiter:".", precision:0) %>
</p>
</div>

<div class="bg-white p-6 rounded-2xl shadow-sm border hover:shadow-md transition">
<p class="text-gray-500 text-sm mb-1">Income Bulan Ini</p>
<p class="text-2xl font-bold text-blue-600">
<%= number_to_currency(@month_income, unit:"Rp ", delimiter:".", precision:0) %>
</p>
</div>

<div class="bg-white p-6 rounded-2xl shadow-sm border hover:shadow-md transition">
<p class="text-gray-500 text-sm mb-1">Total Income</p>
<p class="text-2xl font-bold text-purple-600">
<%= number_to_currency(@total_income, unit:"Rp ", delimiter:".", precision:0) %>
</p>
</div>

</div>

<!-- TABLE -->
<div class="bg-white rounded-2xl shadow-sm border overflow-hidden">

<div class="px-6 py-4 border-b">
<h2 class="font-semibold text-gray-700">
Riwayat Income Pasien
</h2>
</div>

<table class="w-full text-sm">

<thead class="bg-gray-50 text-gray-600">
<tr>
<th class="p-4 text-left">Tanggal</th>
<th class="p-4 text-left">Pasien</th>
<th class="p-4 text-left">Biaya</th>
</tr>
</thead>

<tbody>

<% if @visits.present? %>

<% @visits.each do |visit| %>

<tr class="border-t hover:bg-gray-50 transition">

<td class="p-4 text-center text-gray-700">
<%= visit.visit_date&.strftime("%d %b %Y") %>
</td>

<td class="p-4 text-center font-medium text-gray-800">
<%= visit.patient.name %>
</td>

<td class="p-4 text-center font-semibold text-green-600">
<%= number_to_currency(visit.cost, unit:"Rp ", delimiter:".", precision:0) %>
</td>

</tr>

<% end %>

<% else %>

<tr>
<td colspan="3" class="p-6 text-center text-gray-400">
Belum ada data income.
</td>
</tr>

<% end %>

</tbody>

</table>

</div>

</div>

</section>
