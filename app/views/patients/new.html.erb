<% content_for :title, "Daftar Kunjungan" %>

<section class="py-8 sm:py-12 px-3 sm:px-6 lg:px-8 bg-gray-50 min-h-screen">
  <div class="max-w-2xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6 sm:mb-8 text-center">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
        Daftar Kunjungan
      </h1>
      <p class="mt-1 text-xs sm:text-sm text-gray-500">
        Isi data pasien untuk melakukan pendaftaran
      </p>
    </div>

    <!-- FORM CARD -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-5 sm:p-7">

      <%= render "form", patient: @patient %>

    </div>

    <!-- BACK -->
    <div class="mt-5 text-center">

      <%= link_to patients_path,
          class: "inline-flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600 transition" do %>

        ← <span>Kembali ke daftar pasien</span>

      <% end %>

    </div>

  </div>
</section>