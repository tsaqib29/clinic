<% content_for :title, "Data Kunjungan" %>

<section class="py-10 px-4 sm:px-6 lg:px-8 bg-gray-50 min-h-screen">
  <div class="max-w-6xl mx-auto">

    <!-- Notice -->
    <% if notice.present? %>
      <div class="mb-6 p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm font-medium">
        <%= notice %>
      </div>
    <% end %>

    <!-- Header -->
    <div class="mb-8 flex flex-col gap-6">

      <!-- Title -->
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
          Data Kunjungan Pasien
        </h1>
        <p class="text-sm text-gray-500 mt-1">
          Daftar seluruh pasien yang telah melakukan pendaftaran.
        </p>
      </div>

      <!-- Filter Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 sm:p-6">

        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">

          <!-- Filter Form -->
          <%= form_with url: patients_path, method: :get, local: true, class: "flex flex-col sm:flex-row gap-3 w-full" do |f| %>

            <!-- Search -->
            <div class="relative w-full sm:w-64">
              <%= f.text_field :q,
                  value: params[:q],
                  placeholder: "Cari nama pasien...",
                  class: "w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:outline-none text-sm shadow-sm" %>
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                🔍
              </div>
            </div>

            <!-- Date -->
            <%= f.date_field :patient_date,
                value: params[:patient_date],
                class: "w-full sm:w-44 px-4 py-2.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:outline-none text-sm shadow-sm" %>

            <!-- Filter Button -->
            <%= f.submit "Filter",
                class: "w-full sm:w-auto bg-gray-800 hover:bg-black text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition" %>

            <!-- Reset -->
            <%= link_to "Reset",
                patients_path,
                class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 px-4 py-2.5 rounded-xl text-sm font-medium transition" %>

          <% end %>

          <!-- Add Button -->
          <% if @patients.any? %>
            <%= link_to "＋ Tambah",
                new_patient_path,
                class: "w-full lg:w-auto text-center bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl shadow-md text-sm font-semibold transition" %>
          <% end %>

        </div>

      </div>

    </div>

    <!-- Data -->
    <% if @patients.any? %>
      <div class="space-y-4">

        <% @patients.each do |patient| %>

          <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">

            <!-- Left Info -->
            <div>
              <p class="text-base font-semibold text-gray-800">
                <%= patient.name %> ( <%= patient.address %> )
              </p>
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 mt-2 text-sm text-gray-500">
                <span>📞 <%= patient.phone %></span>
              </div>
            </div>

            <!-- Actions -->
            <div class="grid grid-cols-3 sm:flex gap-2 w-full sm:w-auto">

              <%= link_to "Detail",
                  patient,
                  class: "text-center px-3 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-sm font-medium transition" %>

              <%= link_to "Edit",
                  edit_patient_path(patient),
                  class: "text-center px-3 py-2 rounded-lg bg-yellow-100 hover:bg-yellow-200 text-sm font-medium transition" %>

              <%= button_to "Hapus",
                  patient,
                  method: :delete,
                  data: { turbo_confirm: "Yakin ingin menghapus data ini?" },
                  class: "px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm font-medium transition w-full" %>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <!-- Empty State -->
      <div class="bg-white rounded-2xl shadow-sm p-10 text-center border border-gray-100 max-w-md mx-auto">
        <div class="w-16 h-16 mx-auto rounded-full bg-gray-100 flex items-center justify-center text-gray-400 text-xl mb-4">
          📋
        </div>

        <h3 class="text-lg font-semibold text-gray-700 mb-2">
          Belum Ada Data Kunjungan
        </h3>

        <p class="text-sm text-gray-500 mb-6">
          Silakan tambahkan kunjungan pasien baru.
        </p>

        <%= link_to "＋ Tambah Kunjungan",
            new_patient_path,
            class: "w-full inline-block bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl shadow-md text-sm font-semibold transition text-center" %>
      </div>

    <% end %>

  </div>
</section>
