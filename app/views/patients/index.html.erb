<section class="py-8 sm:py-10 px-3 sm:px-6 lg:px-8 bg-gray-50 min-h-screen">
  <div class="max-w-6xl mx-auto">

    <!-- NOTICE -->
    <% if notice.present? %>
      <div class="mb-6 p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm font-medium shadow-sm">
        <%= notice %>
      </div>
    <% end %>

    <!-- HEADER -->
    <div class="mb-6 sm:mb-8">

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-gray-800">
            Data Kunjungan
          </h1>
          <p class="text-xs sm:text-sm text-gray-500 mt-1">
            Daftar pasien yang sudah terdaftar
          </p>
        </div>

        <%= link_to "＋ Tambah",
            new_patient_path,
            class: "inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-sm font-semibold shadow active:scale-95 transition" %>
      </div>

    </div>

    <!-- FILTER -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 sm:p-5 mb-6">

      <%= form_with url: patients_path, method: :get, local: true,
            class: "grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-4 gap-3" do |f| %>

        <!-- SEARCH -->
        <div class="relative sm:col-span-2">
          <%= f.text_field :q,
              value: params[:q],
              placeholder: "Cari pasien...",
              class: "w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>

          <div class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
            🔍
          </div>
        </div>

        <!-- DATE -->
        <%= f.date_field :patient_date,
            value: params[:patient_date],
            class: "w-full px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>

        <!-- ACTION -->
        <div class="flex gap-2">
          <%= f.submit "Filter",
              class: "flex-1 bg-gray-800 hover:bg-black text-white py-2.5 rounded-xl text-sm font-semibold transition" %>

          <%= link_to "Reset",
              patients_path,
              class: "flex-1 text-center bg-gray-100 hover:bg-gray-200 py-2.5 rounded-xl text-sm font-medium transition" %>
        </div>

      <% end %>
    </div>

    <!-- DATA -->
    <% if @patients.any? %>

      <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-4">

        <% @patients.each do |patient| %>

          <div class="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm hover:shadow-md transition">

            <!-- TOP -->
            <div class="flex justify-between items-start mb-3">
              <div>
                <h3 class="font-semibold text-gray-800 text-sm sm:text-base">
                  <%= patient.name %>
                </h3>
                <p class="text-xs text-gray-400">
                  <%= patient.address %>
                </p>
              </div>

              <span class="text-[10px] bg-blue-100 text-blue-600 px-2 py-1 rounded-full">
                Pasien
              </span>
            </div>

            <!-- INFO -->
            <div class="text-xs text-gray-500 mb-3">
              📞 <%= patient.phone %>
            </div>

            <!-- ACTION -->
            <div class="flex gap-2 justify-end">
              <%= link_to patient,
                  class: "p-2 rounded-lg hover:bg-gray-100 transition" do %>
                👁
              <% end %>

              <!-- EDIT -->
              <%= link_to edit_patient_path(patient),
                  class: "p-2 rounded-lg hover:bg-yellow-100 transition" do %>
                ✏️
              <% end %>

              <!-- DELETE -->
              <%= button_to patient,
                  method: :delete,
                  data: { turbo_confirm: "Yakin hapus?" },
                  class: "p-2 rounded-lg hover:bg-red-100 transition" do %>
                🗑
              <% end %>
            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <!-- EMPTY -->
      <div class="bg-white rounded-2xl shadow-sm p-8 text-center border border-gray-100 max-w-sm mx-auto">

        <div class="w-14 h-14 mx-auto rounded-full bg-gray-100 flex items-center justify-center text-gray-400 text-lg mb-3">
          📋
        </div>

        <h3 class="text-base font-semibold text-gray-700 mb-1">
          Belum Ada Data
        </h3>

        <p class="text-xs text-gray-500 mb-4">
          Tambahkan pasien pertama kamu
        </p>

        <%= link_to "＋ Tambah Pasien",
            new_patient_path,
            class: "inline-block bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-sm font-semibold shadow transition" %>

      </div>

    <% end %>

  </div>
</section>