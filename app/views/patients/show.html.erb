<% content_for :title, "Detail Kunjungan" %>

<div class="max-w-3xl mx-auto px-4 sm:px-0 py-6">

  <% if notice.present? %>
    <div class="mb-6">
      <p class="py-3 px-4 bg-green-50 text-green-600 text-sm font-medium rounded-xl border border-green-100">
        <%= notice %>
      </p>
    </div>
  <% end %>

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
      Detail Kunjungan
    </h1>
    <p class="text-sm text-gray-500 mt-1">
      Informasi lengkap data pasien dan kunjungannya.
    </p>
  </div>

  <!-- Card Data -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 mb-6">
    <%= render @patient %>
  </div>

  <!-- History -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 mb-6">

    <h2 class="text-lg font-semibold text-gray-800 mb-4">
      Riwayat Kunjungan
    </h2>

    <table class="w-full text-sm border-collapse">

      <thead class="border-b bg-gray-50">
        <tr>
          <th class="py-3 px-4 text-left font-semibold text-gray-600 w-1/3">
            <%= link_to "➕", new_patient_visit_path(patient_id: @patient.id) %>
          </th>

          <th class="py-3 px-4 text-left font-semibold text-gray-600 w-1/3">
            Tanggal Datang
          </th>

          <th class="py-3 px-4 text-left font-semibold text-gray-600 w-1/3">
            Kontrol Lagi
          </th>

          <th class="py-3 px-4 text-left font-semibold text-gray-600 w-1/3">
            Biaya
          </th>

          <th class="py-3 px-4 text-center font-semibold text-gray-600 w-24">
            Aksi
          </th>
        </tr>
      </thead>

      <tbody>
        <% @patient.visits.each do |visit| %>
          <tr class="border-b hover:bg-gray-50">

            <td class="py-3 px-4 text-center">
            </td>

            <td class="py-3 px-4 text-center">
              <%= visit.visit_date %>
            </td>

            <td class="py-3 px-4 text-center">
              <%= visit.next_visit_date %>
            </td>

            <td class="py-3 px-4 text-center">
              <%= number_to_currency(visit.cost, unit:"Rp ", delimiter:".", precision:0) %>
            </td>

            <td class="py-3 px-4 text-center">
              <%= link_to "Edit",
                  edit_patient_visit_path(@patient, visit),
                  class:"text-blue-600 hover:text-blue-800 font-medium" %>
            </td>

          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Action Buttons -->
  <div class="flex flex-col sm:flex-row gap-3">

    <%= link_to "✏️ Edit",
        edit_patient_path(@patient),
        class: "w-full sm:w-auto text-center bg-blue-600 hover:bg-blue-700 text-white px-4 py-2.5 rounded-xl shadow-md text-sm font-semibold transition" %>

     <%= button_to "🗑 Hapus",
        @patient,
        method: :delete,
        form_class: "w-full sm:w-auto",
        class: "w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition",
        data: { turbo_confirm: "Yakin ingin menghapus data ini?" } %>
        
    <%= link_to "← Kembali ke Data",
        patients_path,
        class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2.5 rounded-xl text-sm font-medium transition" %>

    <%= link_to "← Kembali ke Kunjungan",
        tomorrow_visits_path,
        class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2.5 rounded-xl text-sm font-medium transition" %>
  </div>

</div>